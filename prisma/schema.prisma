generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  SUPERADMIN
}

enum Plan {
  free
  family
  group
}

enum MemberRole {
  owner
  admin
  member
  child
}

enum TransactionType {
  income
  expense
}

enum GoalStatus {
  active
  completed
  cancelled
}

enum AllowanceFrequency {
  weekly
  monthly
}

enum AllowanceRequestStatus {
  pending
  approved
  rejected
}

// ─── NEXTAUTH ────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── USERS ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  passwordHash  String?   @map("password_hash")
  phone         String?
  role                UserRole  @default(USER)
  onboardingCompleted Boolean   @default(false) @map("onboarding_completed")
  isActive            Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts      Account[]
  sessions      Session[]
  groupMembers  GroupMember[]
  transactions  Transaction[]
  auditLogs     AuditLog[]
  goalsCreated  Goal[]
  activityLogs  ActivityLog[]
  points        Point[]

  @@map("users")
}

// ─── GROUPS ──────────────────────────────────────────────────────────────────

model Group {
  id               String   @id @default(cuid())
  name             String
  type             String   @default("family")
  ownerId          String   @map("owner_id")
  plan             Plan     @default(free)
  stripeCustomerId String?  @map("stripe_customer_id")
  stripeSubId      String?  @map("stripe_sub_id")
  currency         String   @default("BRL")
  timezone         String   @default("America/Sao_Paulo")
  createdAt        DateTime @default(now()) @map("created_at")

  members       GroupMember[]
  transactions  Transaction[]
  categories    Category[]
  budgets       Budget[]
  goals         Goal[]
  allowances    Allowance[]
  missions      Mission[]
  points        Point[]
  auditLogs     AuditLog[]
  invites       GroupInvite[]
  activityLogs  ActivityLog[]

  @@map("groups")
}

model GroupMember {
  id              String     @id @default(cuid())
  groupId         String     @map("group_id")
  userId          String     @map("user_id")
  role            MemberRole @default(member)
  joinedAt        DateTime   @default(now()) @map("joined_at")
  invitedBy       String?    @map("invited_by")
  consentGivenBy  String?    @map("consent_given_by")
  consentGivenAt  DateTime?  @map("consent_given_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

model GroupInvite {
  id         String    @id @default(cuid())
  groupId    String    @map("group_id")
  token      String    @unique
  email      String?
  role       MemberRole @default(member)
  invitedBy  String    @map("invited_by")
  expiresAt  DateTime  @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")
  declinedAt DateTime? @map("declined_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("group_invites")
}

// ─── FINANCE ─────────────────────────────────────────────────────────────────

model Category {
  id        String          @id @default(cuid())
  groupId   String          @map("group_id")
  name      String
  type      TransactionType
  icon      String?
  color     String?
  isSystem  Boolean         @default(false) @map("is_system")
  createdAt DateTime        @default(now()) @map("created_at")

  group        Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@map("categories")
}

model Transaction {
  id                   String          @id @default(cuid())
  groupId              String          @map("group_id")
  userId               String          @map("user_id")
  categoryId           String?         @map("category_id")
  type                 TransactionType
  amount               Decimal         @db.Decimal(15, 2)
  description          String?
  date                 DateTime        @db.Date
  isRecurring          Boolean         @default(false) @map("is_recurring")
  recurringInterval    String?         @map("recurring_interval")
  recurringDay         Int?            @map("recurring_day")
  nextOccurrence       DateTime?       @map("next_occurrence")
  parentTransactionId  String?         @map("parent_transaction_id")
  recurrence           Json?
  attachments          String[]
  tags                 String[]
  metadata             Json            @default("{}")
  createdAt            DateTime        @default(now()) @map("created_at")
  deletedAt            DateTime?       @map("deleted_at")

  group             Group        @relation(fields: [groupId], references: [id])
  user              User         @relation(fields: [userId], references: [id])
  category          Category?    @relation(fields: [categoryId], references: [id])
  parentTransaction Transaction? @relation("RecurringChildren", fields: [parentTransactionId], references: [id])
  childTransactions Transaction[] @relation("RecurringChildren")

  @@index([groupId, date(sort: Desc)])
  @@index([groupId, createdAt(sort: Desc)])
  @@index([nextOccurrence])
  @@map("transactions")
}

model Budget {
  id         String   @id @default(cuid())
  groupId    String   @map("group_id")
  categoryId String   @map("category_id")
  month      DateTime @db.Date
  amount     Decimal  @db.Decimal(15, 2)

  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([groupId, categoryId, month])
  @@map("budgets")
}

// ─── GOALS ───────────────────────────────────────────────────────────────────

model Goal {
  id            String     @id @default(cuid())
  groupId       String     @map("group_id")
  name          String
  description   String?
  targetAmount  Decimal    @db.Decimal(15, 2) @map("target_amount")
  currentAmount Decimal    @db.Decimal(15, 2) @default(0) @map("current_amount")
  targetDate    DateTime?  @map("target_date") @db.Date
  status        GoalStatus @default(active)
  coverUrl      String?    @map("cover_url")
  createdBy     String     @map("created_by")
  createdAt     DateTime   @default(now()) @map("created_at")

  group         Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator       User               @relation(fields: [createdBy], references: [id])
  contributions GoalContribution[]

  @@map("goals")
}

model GoalContribution {
  id        String   @id @default(cuid())
  goalId    String   @map("goal_id")
  userId    String   @map("user_id")
  amount    Decimal  @db.Decimal(15, 2)
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@map("goal_contributions")
}

// ─── ALLOWANCE ───────────────────────────────────────────────────────────────

model Allowance {
  id          String             @id @default(cuid())
  groupId     String             @map("group_id")
  childId     String             @map("child_id")
  amount      Decimal            @db.Decimal(15, 2)
  frequency   AllowanceFrequency
  dayOfMonth  Int?               @map("day_of_month")
  isActive    Boolean            @default(true) @map("is_active")
  createdAt   DateTime           @default(now()) @map("created_at")

  group    Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  requests AllowanceRequest[]

  @@map("allowances")
}

model AllowanceRequest {
  id          String                 @id @default(cuid())
  allowanceId String                 @map("allowance_id")
  amount      Decimal                @db.Decimal(15, 2)
  reason      String?
  status      AllowanceRequestStatus @default(pending)
  reviewedBy  String?                @map("reviewed_by")
  reviewedAt  DateTime?              @map("reviewed_at")
  createdAt   DateTime               @default(now()) @map("created_at")

  allowance Allowance @relation(fields: [allowanceId], references: [id], onDelete: Cascade)

  @@map("allowance_requests")
}

// ─── PASSWORD RESET ─────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("password_reset_tokens")
}

// ─── POINTS ─────────────────────────────────────────────────────────────

model Point {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  groupId   String   @map("group_id")
  amount    Int
  reason    String
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id])
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId, userId])
  @@index([groupId, createdAt(sort: Desc)])
  @@map("points")
}

// ─── MISSIONS ───────────────────────────────────────────────────────────

enum MissionType {
  SPEND_LESS
  SAVE_AMOUNT
  NO_SPEND_CATEGORY
}

enum MissionStatus {
  active
  completed
  failed
}

model Mission {
  id            String        @id @default(cuid())
  groupId       String        @map("group_id")
  title         String
  description   String?
  type          MissionType
  targetAmount  Decimal?      @db.Decimal(15, 2) @map("target_amount")
  currentAmount Decimal       @db.Decimal(15, 2) @default(0) @map("current_amount")
  categoryId    String?       @map("category_id")
  startDate     DateTime      @db.Date @map("start_date")
  endDate       DateTime      @db.Date @map("end_date")
  status        MissionStatus @default(active)
  reward        Int           @default(0)
  createdBy     String        @map("created_by")
  createdAt     DateTime      @default(now()) @map("created_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId, status])
  @@map("missions")
}

// ─── ACTIVITY LOG ───────────────────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(cuid())
  groupId     String   @map("group_id")
  userId      String   @map("user_id")
  action      String
  description String?
  amount      Decimal? @db.Decimal(15, 2)
  entityType  String?  @map("entity_type")
  entityId    String?  @map("entity_id")
  createdAt   DateTime @default(now()) @map("created_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@index([groupId, createdAt(sort: Desc)])
  @@map("activity_logs")
}

// ─── AUDIT ───────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  groupId    String?  @map("group_id")
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  before     Json?
  after      Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  group Group? @relation(fields: [groupId], references: [id])
  user  User?  @relation(fields: [userId], references: [id])

  @@index([groupId, createdAt(sort: Desc)])
  @@map("audit_logs")
}
